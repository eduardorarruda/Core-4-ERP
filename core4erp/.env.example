# ── Banco de dados ────────────────────────────────────────────────────────────
# Em ambiente Docker, use: jdbc:postgresql://db:5432/core4erp
DB_URL=jdbc:postgresql://localhost:5432/core4erp
DB_USERNAME=postgres
DB_PASSWORD=changeme
POSTGRES_DB=core4erp

# Tamanho máximo do pool de conexões HikariCP (padrão 3 para plano gratuito)
DB_POOL_SIZE=3

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
SECRET_KEY=your-secret-key-here
# Expiração em milissegundos (padrão 604800000 = 7 dias)
TOKEN_EXPIRATION=604800000

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# URL do frontend — também usada como base do link de reset de senha
CORS_ORIGINS=https://front.core4erp.codes

# ── AI Chat — OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=your-key-here
# Modelo (padrão gpt-4o-mini — mais econômico com suporte a tools + streaming)
OPENAI_MODEL=gpt-4o-mini

# ── E-mail — reset de senha ───────────────────────────────────────────────────
# MAIL_ENABLED=false  → modo demo: token retornado na resposta (padrão para dev)
# MAIL_ENABLED=true   → produção: token enviado por e-mail
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu@gmail.com
# Gmail: use uma "Senha de app" (App Password), não a senha normal
# https://myaccount.google.com/apppasswords
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=noreply@core4erp.com

# ── Observabilidade ───────────────────────────────────────────────────────────
# Ambiente (development | staging | production) — aparece nas métricas Prometheus
APP_ENV=development

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme
GRAFANA_URL=http://localhost:3001
