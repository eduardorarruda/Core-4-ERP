{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Chat IA — Uso, Custo e Latência",
  "uid": "core4erp-chat-ia",
  "tags": ["core4erp", "chat", "ia"],
  "timezone": "browser",
  "schemaVersion": 39,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Mensagens (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(chat_mensagens_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "stat",
      "title": "Erros (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(chat_erros_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "stat",
      "title": "Sessões ativas",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(chat_sessoes_ativas)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "stat",
      "title": "Custo estimado 24h (USD, gpt-4o-mini)",
      "description": "Estimativa: prompt $0.15/1M + completion $0.60/1M tokens. Ajuste se trocar o modelo.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "(increase(chat_tokens_prompt_total[24h]) * 0.15 + increase(chat_tokens_completion_total[24h]) * 0.60) / 1000000", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens por hora (prompt vs completion)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "increase(chat_tokens_prompt_total[1h])", "legendFormat": "prompt", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "increase(chat_tokens_completion_total[1h])", "legendFormat": "completion", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Custo estimado por hora (USD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "(increase(chat_tokens_prompt_total[1h]) * 0.15 + increase(chat_tokens_completion_total[1h]) * 0.60) / 1000000", "legendFormat": "custo/h", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latência de processamento (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "chat_processamento_duracao_seconds{quantile=\"0.5\"}", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "chat_processamento_duracao_seconds{quantile=\"0.95\"}", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "chat_processamento_duracao_seconds{quantile=\"0.99\"}", "legendFormat": "p99", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Mensagens e erros por hora",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "increase(chat_mensagens_total[1h])", "legendFormat": "mensagens", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "increase(chat_erros_total[1h])", "legendFormat": "erros", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
