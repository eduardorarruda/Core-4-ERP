# Database Produção
DB_URL=jdbc:postgresql://localhost:5432/core4erp
DB_USERNAME=postgres
DB_PASSWORD=changeme

# Database log e Performace
DB_URL_LOG_PER=jdbc:postgresql://localhost:5432/core4erp
DB_USERNAME_LOG_PER=postgres
DB_PASSWORD_LOG_PER=changeme

# JWT — use a long random string (e.g. openssl rand -hex 64)
SECRET_KEY=your-secret-key-here
# Token expiration in milliseconds (default 604800000 = 7 days)
TOKEN_EXPIRATION=604800000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://front.core4erp.codes

# AI Chat — Google Gemini
GEMINI_API_KEY=your-key-here

# Grafana
GRAFANA_PASSWORD=your-grafana-password-here
