# Database Produção
DB_URL=jdbc:postgresql://localhost:5432/core4erp
DB_USERNAME=postgres
DB_PASSWORD=changeme

# Pool de conexões (padrão 3 para plano gratuito; aumentar em produção)
DB_POOL_SIZE=3

# JWT — use a long random string (e.g. openssl rand -hex 64)
SECRET_KEY=your-secret-key-here
# Token expiration in milliseconds (default 604800000 = 7 days)
TOKEN_EXPIRATION=604800000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://front.core4erp.codes

# AI Chat — OpenAI
OPENAI_API_KEY=your-key-here
OPENAI_MODEL=gpt-4o-mini

# Grafana (disponível em http://localhost:3001 por padrão)
GRAFANA_PASSWORD=your-grafana-password-here
GRAFANA_URL=http://localhost:3001

# E-mail — reset de senha
# MAIL_ENABLED=false  →  modo demo: token retornado na resposta (padrão para dev)
# MAIL_ENABLED=true   →  produção: token enviado por e-mail
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu@gmail.com
# Gmail: use uma "Senha de app" (App Password), não a senha normal
# https://myaccount.google.com/apppasswords
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=noreply@core4erp.com
# O link do e-mail de reset usa o primeiro valor de CORS_ORIGINS automaticamente
